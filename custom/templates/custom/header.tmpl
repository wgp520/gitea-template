			font-weight: 500;
			border-radius: 999px !important;
			padding: 0.55rem 1rem !important;
			transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
		}

		#navbar .item:hover, #navbar .item.active {
			background: rgba(59, 130, 246, 0.18) !important;
			color: #f8fafc !important;
			transform: translateY(-1px);
		}

		#navbar .ui.dropdown.jump.item .menu,
		#navbar .ui.dropdown .menu {
			border-radius: 0.85rem;
			border: 1px solid rgba(226, 232, 240, 0.6);
			box-shadow: 0 20px 45px rgba(15, 23, 42, 0.22);
			background: #ffffff;
			color: #0f172a;
			z-index: 1300;
		}

		#navbar .ui.dropdown .menu .item {
			color: #0f172a !important;
			font-weight: 500;
			border-radius: 0.65rem;
			margin: 0.2rem 0.4rem;
			padding: 0.55rem 0.75rem !important;
		}

		#navbar .ui.dropdown .menu .item:hover,
		#navbar .ui.dropdown .menu .item.active {
			background: rgba(37, 99, 235, 0.08) !important;
			color: #1e293b !important;
		}

		#navbar #navbar-logo {
			background: transparent !important;
			padding: 0.45rem 0.75rem !important;
			border-radius: 999px;
			display: block !important; /* 强制显示我们的自定义 Logo */
		}

		#navbar .navbar-mobile-right {
			gap: 0.4rem;
			display: flex !important; /* 强制显示我们的自定义移动端按钮 */
		}

		.page-content {
			margin-top: 1.25rem;
		}

		.home-hero {
			min-height: 65vh;
			display: flex;
			align-items: center;
			background: radial-gradient(circle at top left, rgba(58, 123, 213, 0.15), transparent),
				radial-gradient(circle at bottom right, rgba(52, 211, 153, 0.15), transparent);
			padding: 4rem 0;
		}

		.home-hero .badge {
			letter-spacing: 0.08em;
			font-weight: 600;
		}

		.home-hero h1 {
			font-weight: 700;
			font-size: clamp(2.5rem, 5vw, 3.75rem);
		}

		.home-hero p.lead {
			color: rgba(15, 23, 42, 0.75);
			font-size: 1.15rem;
		}

		.home-stat-card {
			border-radius: 1rem;
			border: none;
			box-shadow: 0 14px 45px rgba(15, 23, 42, 0.08);
			transition: transform 0.3s ease, box-shadow 0.3s ease;
		}

		.home-stat-card:hover {
			transform: translateY(-6px);
			box-shadow: 0 18px 60px rgba(15, 23, 42, 0.12);
		}

		.feature-icon {
			width: 3rem;
			height: 3rem;
			border-radius: 0.75rem;
